    { "id": "linkedin",  "status": "reference", "path": "channels/linkedin" },
    { "id": "instagram", "status": "active",    "path": "channels/instagram" },
    { "id": "facebook",  "status": "active",    "path": "channels/facebook" },
    { "id": "x",         "status": "active",    "path": "channels/x" },
