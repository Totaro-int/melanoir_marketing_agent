    { "id": "bluesky",   "status": "active",    "path": "channels/bluesky" },
    { "id": "mastodon",  "status": "active",    "path": "channels/mastodon" },
    { "id": "pinterest", "status": "active",    "path": "channels/pinterest" },
    { "id": "tiktok",    "status": "active",    "path": "channels/tiktok" },
    { "id": "youtube",   "status": "active",    "path": "channels/youtube" }
