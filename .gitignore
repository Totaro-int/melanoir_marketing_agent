# 회사 프로필·자격증명 — 절대 커밋 금지
company-profile.yaml
company-profile.local.yaml
marketing-sources.yaml
*.local.yaml
.env
.env.*
!.env.example

# SNS 세션·쿠키
sessions/
cookies/
auth/
# harness/examples/auth/ 는 placeholder (실 토큰 아님) — 커밋 허용.
!harness/examples/auth/
!harness/examples/auth/*.json

# 생성된 이미지·빌드 산출물
out/

# 캠페인 데이터 — 고객사별 실제 데이터이므로 전체 제외 (템플릿에 포함 X)
posts/campaigns/

# symlink 자동 생성물 (sync-posts.mjs)
posts/by-channel/

# 반복 실행 슬롯 (개인 데이터)
posts/slots.yaml

# 학습된 사용자 선호도 (개인 데이터, approve/reject 시 자동 누적)
posts/preferences.yaml

# 브랜드 지침 원문 (클라가 넣는 브랜드북 PDF/md 등 — 개인 데이터). 안내 README 만 커밋.
posts/sources/*
!posts/sources/README.md

# 인사이트 카드 배경용 클라 사진 풀 (개인 데이터). .gitkeep 만 커밋.
posts/insight-photos/*
!posts/insight-photos/.gitkeep

# 인사이트 카드 토픽 (per-install 콘텐츠) + 실행 로그 (휘발성) — 트리 더럽힘 방지
insights-topics.txt
logs/

# 개발 중 디버깅 probe 스크립트 (커밋 X)
harness/bin/_temp-*

# 리버스 엔지니어링 분석 자료 (큰 파일 + 외부 코드)
_research/

# 회사 자체 자산 (제품 사진 등)
assets/

# 내부 개발 메모 (납품용 레포에 불필요)
docs/sj-company/
docs/superpowers/

# 백업 파일 (회사 프로필, draft 인라인 편집 백업, original 보존본)
*.bak.yaml
*.bak.json
*.yaml.bak
*.json.bak
*.original.yaml

# 발행 진행 로그 (휘발성)
posts/campaigns/**/publish.log

# 노드/툴링
node_modules/
# package-lock.json: npm install 이 npm 버전 차이로 재작성 → 트리가 더러워지고 self-update `git pull` 이 충돌.
# 각 머신에서 로컬 생성하도록 추적 제외 (이 하네스는 느슨한 버전 범위라 재현성 영향 미미).
package-lock.json
.pnpm-store/
dist/
build/
*.log
.DS_Store

# IDE
.vscode/
.idea/
*.swp

# Claude Code 로컬 상태
.claude/state/
.claude/cache/

out/.update-check
.claude/
