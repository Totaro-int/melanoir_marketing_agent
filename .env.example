# marketing_agent 환경변수 예시
# 실제 값은 .env.local 에 두고 절대 커밋하지 마세요 (.gitignore에 포함됨).

# 활성 provider 선택 (mock | openai | inhouse). 기본 mock.
CONTENT_ENGINE_PROVIDER=mock

# OpenAI BYO 키 (CONTENT_ENGINE_PROVIDER=openai 일 때만 사용)
# OPENAI_API_KEY=sk-...
# OPENAI_COPY_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=gpt-image-1

# 자사 게이트웨이는 Phase 4+ 에 활성화
# UPFLOW_CONTENT_API_KEY=
# UPFLOW_CONTENT_API_URL=
