# marketing_agent 환경변수 예시
# 실제 값은 .env.local 에 두고 절대 커밋하지 마세요 (.gitignore에 포함됨).
# bin/_lib.mjs 가 모듈 로드 시 .env.local 을 자동으로 process.env 에 머지합니다.

# 활성 provider 선택 (inhouse-slides | fal | openai) — 미설정 시 inhouse-slides.
# 권장(기본): inhouse-slides — 카피·슬라이드를 Claude Code 서브에이전트가 직접 생성.
#             외부 API 키 0개. Playwright 만 있으면 됨.
# 또는: fal (AI 이미지 생성) → CONTENT_ENGINE_PROVIDER=fal + FAL_KEY
CONTENT_ENGINE_PROVIDER=inhouse-slides
# CONTENT_ENGINE_PROVIDER=fal

# ⚠ ANTHROPIC_API_KEY 는 사용하지 않습니다.
#   카피·슬라이드는 Claude Code 세션 안의 서브에이전트(copywriter / image-director)가
#   만듭니다 — 별도 API 호출 없음. (anthropic provider 도 byok:false)

# fal.ai BYO 키 (provider=fal 일 때만 — 결과가 fal CDN URL로 반환되어 그대로 발행 가능)
# FAL_KEY=<from https://fal.ai/dashboard/keys>
# FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1

# OpenAI BYO 키 (provider=openai 일 때만 — 이미지 생성 전용. 카피는 서브에이전트가 담당)
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=medium

# 발행 안전 모드 — true 면 /publish 가 네트워크 호출 없이 페이로드만 출력
# PUBLISHER_DRY_RUN=true

# 추가 API 연동 (Phase 6 이후)
# CONTENT_GATEWAY_API_KEY=
# CONTENT_GATEWAY_API_URL=
