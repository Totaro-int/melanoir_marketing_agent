# marketing_agent 환경변수 예시
# 실제 값은 .env.local 에 두고 절대 커밋하지 마세요 (.gitignore에 포함됨).
# bin/_lib.mjs 가 모듈 로드 시 .env.local 을 자동으로 process.env 에 머지합니다.

# 활성 provider 선택 (fal | openai | anthropic | inhouse-slides) — 필수, 미설정 시 오류.
# 권장: inhouse-slides (Claude HTML 슬라이드 + Playwright 스크린샷, 외부 이미지 API 불필요)
# 또는: fal (이미지 AI 생성) + Claude 카피 → CONTENT_ENGINE_PROVIDER=fal + ANTHROPIC_API_KEY + FAL_KEY
CONTENT_ENGINE_PROVIDER=inhouse-slides
# CONTENT_ENGINE_PROVIDER=fal

# Anthropic API 키 — Claude가 카피를 직접 생성 (provider=fal, anthropic, inhouse-slides 시 사용)
# Claude Code 계정과 동일한 키. https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_COPY_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_SLIDE_MODEL=claude-sonnet-4-6  # inhouse-slides 슬라이드 생성 모델 (기본값)

# fal.ai BYO 키 (이미지 생성 권장 — 결과가 fal CDN URL로 반환되어 그대로 발행 가능)
# FAL_KEY=<from https://fal.ai/dashboard/keys>
# FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1

# OpenAI BYO 키 (카피 + 이미지 모두 OpenAI 사용 시)
# OPENAI_API_KEY=sk-...
# OPENAI_COPY_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=gpt-image-1

# 발행 안전 모드 — true 면 /publish 가 네트워크 호출 없이 페이로드만 출력
# PUBLISHER_DRY_RUN=true

# 추가 API 연동 (Phase 6 이후)
# CONTENT_GATEWAY_API_KEY=
# CONTENT_GATEWAY_API_URL=
