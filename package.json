{
  "name": "melanoir-marketing-agent",
  "version": "0.9.1",
  "private": true,
  "description": "Totaro SNS 마케팅 자동화 하네스 — Claude Code 플러그인",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "marketing-agent": "harness/bin/cli.mjs"
  },
  "scripts": {
    "validate": "node harness/bin/profile-validate.mjs",
    "validate:example": "node harness/bin/profile-validate.mjs harness/examples/company-profile.example.yaml",
    "profile:show": "node harness/bin/profile-show.mjs",
    "campaign:new": "node harness/bin/campaign-new.mjs",
    "generate": "node harness/bin/generate.mjs",
    "preview": "node harness/bin/preview.mjs",
    "approve": "node harness/bin/approve.mjs",
    "reject": "node harness/bin/reject.mjs",
    "browser-publish": "node harness/bin/browser-publish.mjs",
    "deck": "node harness/bin/copy-deck.mjs",
    "cookies": "node harness/bin/cookie-store.mjs",
    "status": "node harness/bin/board.mjs",
    "status:watch": "node harness/bin/board.mjs --watch",
    "doctor": "node harness/bin/doctor.mjs",
    "self-check": "node harness/bin/self-check.mjs",
    "self-check:fix": "node harness/bin/self-check.mjs --fix",
    "morning": "node harness/bin/morning-routine.mjs",
    "morning:dry": "node harness/bin/morning-routine.mjs --dry-run",
    "setup": "node harness/bin/setup.mjs",
    "run": "node harness/bin/run.mjs",
    "schedule": "node harness/bin/schedule-plan.mjs",
    "queue:tick": "node harness/bin/queue-tick.mjs",
    "queue:dry": "node harness/bin/queue-tick.mjs --dry-run",
    "queue:install": "node harness/bin/install-cron.mjs install",
    "sync-posts": "node harness/bin/sync-posts.mjs",
    "seed-calendar": "node harness/bin/seed-calendar.mjs",
    "insight:card": "node harness/bin/insight-card.mjs",
    "insight:daily": "node harness/bin/insight-daily.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pdfjs-dist": "^6.0.227",
    "picocolors": "^1.1.1",
    "playwright": "^1.59.1",
    "yaml": "^2.6.1"
  }
}
