{
  "name": "marketing_agent",
  "version": "0.6.0",
  "private": true,
  "description": "Totaro SNS 마케팅 자동화 하네스 — Claude Code 플러그인",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "marketing-agent": "bin/cli.mjs"
  },
  "scripts": {
    "validate":         "node bin/profile-validate.mjs",
    "validate:example": "node bin/profile-validate.mjs examples/company-profile.example.yaml",
    "profile:show":     "node bin/profile-show.mjs",
    "campaign:new":     "node bin/campaign-new.mjs",
    "generate":         "node bin/generate.mjs",
    "preview":          "node bin/preview.mjs",
    "approve":          "node bin/approve.mjs",
    "reject":           "node bin/reject.mjs",
    "publish":          "node bin/publish.mjs",
    "publish:dry":      "PUBLISHER_DRY_RUN=true node bin/publish.mjs",
    "auth":             "node bin/auth.mjs",
    "status":           "node bin/board.mjs",
    "status:watch":     "node bin/board.mjs --watch"
  },
  "dependencies": {
    "ajv":         "^8.17.1",
    "ajv-formats": "^3.0.1",
    "picocolors":  "^1.1.1",
    "yaml":        "^2.6.1"
  }
}
